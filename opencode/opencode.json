{
  "$schema": "https://opencode.ai/config.json",
  "experimental": {
    "mcp_timeout": 10000
  },
  "lsp": true,
  "mcp": {
    "supabase": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@supabase/mcp-server-supabase@latest",
        "--read-only",
        "--project-ref=ehvopzzidrfxtvsfrfkq"
      ],
      "environment": {
        "SUPABASE_ACCESS_TOKEN": "{env:SUPABASE_ACCESS_TOKEN}"
      }
    },
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp"
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "logfire": {
      "type": "remote",
      "url": "https://logfire-us.pydantic.dev/mcp"
    },
    "notion": {
      "type": "remote",
      "url": "https://mcp.notion.com/mcp"
    }
  },
  "watcher": {
    "ignore": [
      ".git/**",
      "node_modules/**",
      ".venv/**",
      ".pytest_cache/**",
      ".mypy_cache/**"
    ]
  }
}
